{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Burned",
  "version": "0.2.1",
  "identifier": "com.burned.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Burned",
        "width": 1440,
        "height": 940,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
